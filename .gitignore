.DS_Store
.env
.env.*
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# Local doc store (must never be committed — large data)
cex-docs/
cex-docs-*/

# POC output data (large, regenerable)
poc-binance-full/
poc-*.jpeg
# Bug reports are local artifacts, not committed
bug-reports/*.md
!bug-reports/README.md
