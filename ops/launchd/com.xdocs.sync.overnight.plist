<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  SETUP:
    sed "s|/Users/YOURUSER/xdocs|$(pwd)|g" \
      ops/launchd/com.xdocs.sync.overnight.plist \
      > ~/Library/LaunchAgents/com.xdocs.sync.overnight.plist
    launchctl load ~/Library/LaunchAgents/com.xdocs.sync.overnight.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.xdocs.sync.overnight</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd /Users/YOURUSER/xdocs &amp;&amp; scripts/run_sync_preset.sh overnight-safe ./cex-docs &gt;&gt; logs/launchd-sync.log 2&gt;&amp;1</string>
  </array>

  <key>RunAtLoad</key>
  <false/>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>2</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>WorkingDirectory</key>
  <string>/Users/YOURUSER/xdocs</string>

  <key>StandardOutPath</key>
  <string>/Users/YOURUSER/xdocs/logs/launchd-sync.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOURUSER/xdocs/logs/launchd-sync.err.log</string>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
